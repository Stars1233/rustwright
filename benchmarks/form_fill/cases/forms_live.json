[
  {
    "id": "internet_login_success",
    "category": "navigation",
    "url": "https://the-internet.herokuapp.com/login",
    "nav_steps": [
      {
        "op": "goto",
        "url": "https://the-internet.herokuapp.com/login"
      },
      {
        "op": "wait",
        "selector": "#username"
      },
      {
        "op": "fill",
        "selector": "#username",
        "value": "tomsmith"
      },
      {
        "op": "fill",
        "selector": "#password",
        "value": "SuperSecretPassword!"
      },
      {
        "op": "hover",
        "selector": "#login button[type='submit']"
      },
      {
        "op": "click",
        "selector": "#login button[type='submit']"
      },
      {
        "op": "wait",
        "selector": "#flash"
      },
      {
        "op": "eval",
        "expression": "document.querySelector('#flash').textContent.trim()"
      }
    ]
  },
  {
    "id": "internet_checkbox_state_cycle",
    "category": "navigation",
    "url": "https://the-internet.herokuapp.com/checkboxes",
    "nav_steps": [
      {
        "op": "goto",
        "url": "https://the-internet.herokuapp.com/checkboxes"
      },
      {
        "op": "wait",
        "selector": "#checkboxes input[type='checkbox']"
      },
      {
        "op": "uncheck",
        "selector": "#checkboxes input:nth-of-type(2)"
      },
      {
        "op": "check",
        "selector": "#checkboxes input:nth-of-type(1)"
      },
      {
        "op": "uncheck",
        "selector": "#checkboxes input:nth-of-type(1)"
      },
      {
        "op": "check",
        "selector": "#checkboxes input:nth-of-type(2)"
      },
      {
        "op": "hover",
        "selector": "#checkboxes input:nth-of-type(1)"
      },
      {
        "op": "eval",
        "expression": "Array.from(document.querySelectorAll(\"#checkboxes input[type='checkbox']\")).map(input => input.checked)"
      }
    ]
  },
